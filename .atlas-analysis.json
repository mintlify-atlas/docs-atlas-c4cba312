  "keyFeatures": [
    "Public storefront with bike products, electric motos, and electric conversion kits",
    "WhatsApp-integrated contact and product inquiry flow",
    "Admin dashboard with product CRUD and inventory management",
    "Category management with auto-generated slugs",
    "News/newsletter module with rich article publishing",
    "Supabase backend for auth, database, and image storage",
    "Automatic WebP image conversion on upload",
    "Paginated and filterable product table",
    "Per-category dynamic spec fields (aro, material, potencia, autonomía, etc.)",
    "Session-based authentication with redirect protection"
  ],
  "publicApiSurface": [
    "supabase.from('products').select / insert / update / delete",
    "supabase.from('categories').select / insert / update / delete",
    "supabase.from('news').select / insert / update / delete",
    "supabase.storage.from('products').upload / getPublicUrl",
    "supabase.storage.from('news').upload / getPublicUrl",
    "supabase.auth.getSession()",
    "supabase.auth.signOut()",
    "useGlobalData() — GlobalContext hook exposing phone, WhatsApp URLs, email, social links",
    "convertToWebP(file, quality) — client-side image conversion utility",
    "Page routes: / (storefront), /login, /dashboard"
  ]
